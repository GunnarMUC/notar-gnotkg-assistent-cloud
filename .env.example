# Notar GNotKG Assistent – Cloud-Version (API-Only)
# Kopiere diese Datei nach .env und passe die Werte an.
# Hinweis: API-Keys werden normalerweise verschlüsselt in der App eingegeben.
#         Die Umgebungsvariablen hier sind ein optionaler Fallback für Fortgeschrittene.

# LLM Provider (mistral | anthropic | xai | moonshot | deepseek)
LLM_PROVIDER=mistral
# LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# Optionale API-Keys (Fallback über .env)
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# MOONSHOT_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# App
APP_OCR_ENABLED=true
APP_OCR_LANG=deu
APP_DEFAULT_OUTPUT_FORMAT=docx
APP_MAX_UPLOAD_SIZE_MB=50
APP_GNOTKG_CHECK_ENABLED=true

# Pfade (relativ zum Projektverzeichnis)
DATA_DIR=data
HISTORY_DIR=history
FEE_TABLES_DIR=data/fee_tables
